BROWSER_CHANNEL=chrome
HEADLESS=true
DEFAULT_TIMEOUT_MS=30000
AUTH_FILE=playwright/.auth/user.json
BROWSER=chromium

# Production login (use secrets in CI, values here are placeholders)
TRIO_PROD_EMAIL=replace-me@example.com
TRIO_PROD_PASSWORD=replace-me

# Signup credentials / inputs
